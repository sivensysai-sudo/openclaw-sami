ENABLED=false
SESSION_DIR=./session
STATE_DIR=./state
LOG_DIR=./logs

# Batasi hanya grup tertentu (comma-separated JID). Kosong = semua grup.
GROUP_ALLOWLIST=

WELCOME_TEMPLATE=Assalamu’alaikum warahmatullahi wabarakatuh.\nSelamat bergabung di grup ini, {name}.\nSaya SAMI — Support Assistant Maslam Interactive, asisten virtual resmi dari Maslam yang siap membantu penggunaan layanan Maslam: panduan fitur, langkah penggunaan, dan troubleshooting.\nJika ada pertanyaan seputar aplikasi Maslam, silakan langsung tanyakan di grup ini, insyaAllah SAMI siap membantu.

RETRY_MAX=3
RETRY_DELAY_MS=1500
